# Copy this file to .env (for local dev) or set these in Vercel Dashboard
# (Project → Settings → Environment Variables) for production.

# REQUIRED — Resend API key. Get one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL — override default lead recipient
# LEAD_RECIPIENT=e.morodenko@mail.ru

# OPTIONAL — override default sender (must be verified domain in Resend, OR
# use the default onboarding@resend.dev which only sends to the email used
# to register the Resend account)
# LEAD_FROM=Сайт Мороденко <leads@morodenko-psy.ru>
